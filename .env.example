# ========================================
# Mobile Test Generator - Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual values

# ========================================
# AI/LLM Provider Configuration
# ========================================
# Options: openai, mock
VISION_AGENT_PROVIDER=openai
TESTCASE_AGENT_PROVIDER=openai

# ========================================
# OpenAI / LiteLLM Gateway Configuration
# ========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional: Custom API endpoint (for Azure OpenAI, LiteLLM, or custom gateways)
# For LiteLLM Gateway, use: http://your-gateway-url:port/v1
# Example: http://107.22.98.31:10501/v1
OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Custom headers for LiteLLM or other gateways
# Format: HEADER_NAME=value (comma-separated for multiple)
# Example: CUSTOM_LLM_HEADERS=x-litellm-api-key
CUSTOM_LLM_HEADERS=

# ========================================
# Appium Server Configuration
# ========================================
APPIUM_SERVER_URL=http://127.0.0.1:4723

# ========================================
# Android App Configuration
# ========================================
APP_PACKAGE=com.saucelabs.mydemoapp.android
APP_ACTIVITY=com.saucelabs.mydemoapp.android.view.activities.SplashActivity
PLATFORM_NAME=Android
AUTOMATION_NAME=UiAutomator2
DEVICE_NAME=Android Emulator

# ========================================
# Path Configuration
# ========================================
# Leave empty to auto-detect project root
PROJECT_ROOT=
# Path to your APK file (use forward slashes or double backslashes)
APP_PATH=demo_mobile_apps/mda-2.2.0-25.apk

# ========================================
# Artifacts Configuration
# ========================================
ARTIFACTS_DIR=artifacts
INPUT_SCREENSHOTS_DIR=artifacts/input_screenshots
SSM_OUTPUT_DIR=artifacts/ssm_json_output
MANUAL_TESTCASES_DIR=artifacts/manual_testcases
LOCATOR_OUTPUT_DIR=artifacts/locator_output
GENERATED_SCRIPTS_DIR=artifacts/generated_appium_scripts
REVIEW_REPORTS_DIR=artifacts/review_reports
TEST_REPORTS_DIR=artifacts/test_execution_reports

# ========================================
# Self-Healing Configuration
# ========================================
SELF_HEALING_ENABLED=true
# Maximum retries for failed locators before triggering AI healing
HEALING_MAX_RETRIES=3
# Enable AI vision-based healing as fallback
AI_VISION_HEALING=true
# Store healed locators for future runs
HEALING_REPOSITORY_ENABLED=true

# ========================================
# Test Execution Configuration
# ========================================
# Timeout for WebDriverWait (seconds)
EXPLICIT_WAIT_TIMEOUT=10
# Implicit wait timeout (seconds)
IMPLICIT_WAIT_TIMEOUT=5
# Auto-open browser after test execution
AUTO_OPEN_BROWSER=true

# ========================================
# Logging Configuration
# ========================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(message)s

# ========================================
# Performance & Caching
# ========================================
# Enable caching for LLM responses to reduce costs
ENABLE_LLM_CACHE=true
# Cache backend: memory, redis, file
CACHE_BACKEND=file
# Cache TTL in seconds (24 hours)
CACHE_TTL=86400

# ========================================
# Cost Tracking
# ========================================
# Enable token usage and cost tracking
ENABLE_TOKEN_TRACKING=true
# Log file for cost tracking
TOKEN_TRACKING_LOG=artifacts/token_usage.log
